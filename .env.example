# AI Cardiovascular Risk Platform — Environment Variables
# Copy this file to .env and fill in the values

# ── Backend ──────────────────────────────────────────────────────────────────

# Port the FastAPI server listens on
PORT=8000

# Directories
MODEL_PATH=models/
DATA_PATH=data/

# CORS — comma-separated list of allowed origins (use * for development)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────

# Vite dev server port (set in vite.config.js; listed here for reference)
VITE_PORT=5173

# Backend API base URL used by the frontend (override in production)
# In development the Vite proxy handles routing, so this can stay empty.
VITE_API_BASE_URL=
